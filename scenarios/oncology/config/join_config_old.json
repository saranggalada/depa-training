      "joining_query": "SELECT g.cell_id, g.patient, g.type as cell_type, g.sc_expr_matrix, p.drug_response, c.cell_markers, ci.cell_metadata FROM genomics_lab g LEFT JOIN pharmaceutical_company p ON g.patient = p.patient_id LEFT JOIN computational_biology_lab c ON g.patient = c.patient_id LEFT JOIN cancer_institute ci ON g.patient = ci.patient_id",
