{
  "name": "Train_XGB",
  "config": {
    "paths": {
      "input_dataset_path": "/tmp/oncology_feat_engg.csv",
      "trained_model_output_path": "/mnt/remote/output"
    },
    "is_private": true,
    "privacy_params": {
      "epsilon": 7.5,
      "delta": null,
      "mechanism": "laplace"
    },
    "model_config": {
      "num_boost_round": 250,
      "booster_params": {
        "max_depth": 6,
        "learning_rate": 0.05,
        "l2_regularization": 1.0,
        "min_child_weight": 1.0,
        "objective": "regression",
        "eval_metric": "rmse"
      }
    },
    "dataset_config": {
      "type": "tabular",
      "target_variable": "drug_response",
      "preprocessing": {
        "scaler": "standard"
      },
      "missing_strategy": "drop",
      "splits": {
        "train": 0.8,
        "val": 0.1,
        "test": 0.1,
        "random_state": 42
      },
      "data_type": "numpy"
    },
    "metrics": [
      "rmse",
      "mae",
      "r2_score"
    ],
    "task_type": "regression"
  }
}
