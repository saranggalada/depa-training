FROM nvidia/cuda:12.4.1-devel-ubuntu22.04

ENV DEBIAN_FRONTEND="noninteractive"
ENV PYTHONUNBUFFERED=1

RUN apt-get update && apt-get -y upgrade \
    && apt-get install -y curl git python3 python3-dev python3-distutils \
    && apt-get install -y jq \
    && rm -rf /var/lib/apt/lists/*

RUN curl https://bootstrap.pypa.io/get-pip.py -o get-pip.py && python3 get-pip.py && rm get-pip.py

# pytorch CUDA
RUN pip3 install --no-cache-dir torch torchvision --index-url https://download.pytorch.org/whl/cu124

# HuggingFace ecosystem
RUN pip3 install --no-cache-dir \
    transformers>=4.40 \
    datasets>=2.18 \
    accelerate>=0.29 \
    peft>=0.10 \
    trl>=0.8 \
    safetensors>=0.4 \
    tokenizers>=0.19

# quantization
RUN pip3 install bitsandbytes>=0.43
# differential privacy
RUN pip3 install opacus>=1.5
# observability
RUN pip3 install mlflow>=2.12
# config
RUN pip3 install jsonschema>=4.20 pyyaml>=6.0
# data processing
RUN pip3 install pyarrow pandas
# flash attention 2 (optional, build from source for CUDA compat)
RUN pip3 install flash-attn --no-build-isolation
# deepspeed (optional, for distributed training)
RUN pip3 install deepspeed
# axolotl (optional)
RUN pip3 install axolotl
# torchtune (optional)
RUN pip3 install torchtune
# legacy deps for backward compat with existing pytrain tasks
RUN pip3 install \
    onnx onnx2pytorch onnxscript scikit-learn scipy \
    h5py xgboost

# install pytrain package
COPY train/dist/pytrain-0.0.1-py3-none-any.whl .
RUN pip3 install pytrain-0.0.1-py3-none-any.whl

COPY train/run.sh run.sh
